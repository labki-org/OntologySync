{
	"name": "labki/ontology-sync",
	"type": "mediawiki-extension",
	"description": "Connects MediaWiki wikis to the Labki ontology via SMW's content importer",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.1.0",
		"composer/installers": "^1.0.1|^2.0"
	},
	"require-dev": {
		"mediawiki/mediawiki-codesniffer": "^48.0",
		"mediawiki/mediawiki-phan-config": "0.14.0",
		"mediawiki/core": "^1.44,<1.45",
		"mediawiki/minus-x": "1.1.3",
		"php-parallel-lint/php-console-highlighter": "1.0.0",
		"php-parallel-lint/php-parallel-lint": "1.4.0",
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"MediaWiki\\Extension\\OntologySync\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"MediaWiki\\Extension\\OntologySync\\Tests\\": "tests/phpunit/"
		}
	},
	"scripts": {
		"test": [
			"parallel-lint . --exclude vendor --exclude node_modules",
			"minus-x check .",
			"@phpcs"
		],
		"fix": [
			"minus-x fix .",
			"phpcbf"
		],
		"phan": "phan -d . --long-progress-bar",
		"phpcs": "phpcs -sp --cache"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"wikimedia/composer-merge-plugin": true,
			"composer/installers": true
		},
		"platform": {
			"php": "8.1"
		}
	}
}
