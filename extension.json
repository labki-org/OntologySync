{
	"name": "OntologySync",
	"version": "0.1.0",
	"author": [
		"Labki"
	],
	"url": "https://github.com/labki-org/OntologySync",
	"descriptionmsg": "ontologysync-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "semantic",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"extensions": {
			"SemanticMediaWiki": "*",
			"SemanticSchemas": "*"
		}
	},
	"namespaces": [
		{
			"id": 3400,
			"constant": "NS_ONTOLOGY_DASHBOARD",
			"name": "OntologyDashboard",
			"content": true
		},
		{
			"id": 3401,
			"constant": "NS_ONTOLOGY_DASHBOARD_TALK",
			"name": "OntologyDashboard_talk"
		},
		{
			"id": 3402,
			"constant": "NS_ONTOLOGY_RESOURCE",
			"name": "OntologyResource",
			"content": true
		},
		{
			"id": 3403,
			"constant": "NS_ONTOLOGY_RESOURCE_TALK",
			"name": "OntologyResource_talk"
		}
	],
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\OntologySync\\": "src/"
	},
	"ServiceWiringFiles": [
		"src/ServiceWiring.php"
	],
	"MessagesDirs": {
		"OntologySync": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"OntologySyncAlias": "OntologySync.alias.php"
	},
	"SpecialPages": {
		"OntologySync": {
			"class": "MediaWiki\\Extension\\OntologySync\\Special\\SpecialOntologySync",
			"services": [
				"OntologySync.GitService",
				"OntologySync.RepoInspector",
				"OntologySync.StagingService",
				"OntologySync.ImportService",
				"OntologySync.HashService",
				"OntologySync.PageResolver",
				"OntologySync.BundleStore",
				"OntologySync.ModuleStore",
				"OntologySync.PageStore"
			]
		}
	},
	"HookHandlers": {
		"OntologySyncHooks": {
			"class": "MediaWiki\\Extension\\OntologySync\\Hooks\\OntologySyncHooks"
		},
		"PageDisplayHooks": {
			"class": "MediaWiki\\Extension\\OntologySync\\Hooks\\PageDisplayHooks",
			"services": [
				"OntologySync.PageStore",
				"OntologySync.BundleStore"
			]
		},
		"SchemaHooks": {
			"class": "MediaWiki\\Extension\\OntologySync\\Hooks\\SchemaHooks"
		}
	},
	"Hooks": {
		"SetupAfterCache": "OntologySyncHooks",
		"ArticleViewFooter": "PageDisplayHooks",
		"LoadExtensionSchemaUpdates": "SchemaHooks"
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "OntologySync"
	},
	"ResourceModules": {
		"ext.ontologysync.styles": {
			"styles": [
				"resources/ext.ontologysync.styles.css"
			],
			"targets": [ "desktop", "mobile" ]
		}
	},
	"AvailableRights": [
		"ontologysync-manage"
	],
	"GroupPermissions": {
		"sysop": {
			"ontologysync-manage": true
		}
	},
	"LogTypes": [
		"ontologysync"
	],
	"LogNames": {
		"ontologysync": "ontologysync-log-name"
	},
	"LogHeaders": {
		"ontologysync": "ontologysync-log-header"
	},
	"LogActionsHandlers": {
		"ontologysync/install": "LogFormatter",
		"ontologysync/update": "LogFormatter",
		"ontologysync/remove": "LogFormatter"
	},
	"config": {
		"OntologySyncBundlePath": {
			"value": null,
			"description": "Absolute path to a bundle version directory containing a *.vocab.json manifest and .wikitext entity files. Set this to enable ontology import via update.php."
		},
		"OntologySyncRepoUrl": {
			"value": "https://github.com/labki-org/labki-ontology",
			"description": "Git URL of the labki-ontology repository to clone."
		},
		"OntologySyncRepoPath": {
			"value": null,
			"description": "Local filesystem path where the labki-ontology repo is cloned. Must be set for the extension to function."
		},
		"OntologySyncStagingPath": {
			"value": null,
			"description": "Path for staging import artifacts. Defaults to $wgCacheDirectory/ontologysync-staging if null."
		},
		"OntologySyncAutoRegisterStaging": {
			"value": true,
			"description": "If true, automatically register the staging directory with SMW's $smwgImportFileDirs when it contains a vocab.json."
		}
	},
	"manifest_version": 2
}
